# Copy this file to .env at the repository root and fill in only the
# credentials needed for the datasets/models you are allowed to access.

# Hugging Face token. Required for gated models such as some Llama,
# Gemma/MedGemma, or other restricted checkpoints.
HF_TOKEN=

# PhysioNet credentials. Required for BRSET and mBRSET.
PHYSIONET_USERNAME=
PHYSIONET_PASSWORD=

# Backward-compatible spelling used by older local scripts.
PHYSION_USERNAME=
PHYSION_PASSWORD=

# Optional: set if external APIs are used in local experiments.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
